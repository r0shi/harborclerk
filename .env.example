# PostgreSQL
DATABASE_URL=postgresql+asyncpg://harbor_clerk:harbor_clerk_dev_password@postgres:5432/harbor_clerk
POSTGRES_USER=harbor_clerk
POSTGRES_PASSWORD=harbor_clerk_dev_password
POSTGRES_DB=harbor_clerk

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=originals
MINIO_USE_SSL=false

# Embedder
EMBEDDER_URL=http://embedder:8000

# Tika
TIKA_URL=http://tika:9998

# App
API_HOST=0.0.0.0  # Docker needs 0.0.0.0; defaults to 127.0.0.1 when unset
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
